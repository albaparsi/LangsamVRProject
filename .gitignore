# =============================================================================
# Unity generated folders (regenerated by the editor — never commit)
# =============================================================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# =============================================================================
# Assets/ and Packages/ — only track scripts (.cs) and scenes (.unity), plus
# their .meta files. Everything else (textures, models, audio, prefabs, embedded
# third-party SDKs, etc.) is ignored to keep the repo small. Note: the project
# will not be reconstructible from git alone — scenes will have missing
# references and embedded packages won't compile without their binary assets.
# =============================================================================
**/[Aa]ssets/**
**/[Pp]ackages/**
# Keep directory entries so git can recurse into subfolders
!**/[Aa]ssets/
!**/[Aa]ssets/**/
!**/[Pp]ackages/
!**/[Pp]ackages/**/
# Re-include scripts, scenes, and their meta files
!**/[Aa]ssets/**/*.cs
!**/[Aa]ssets/**/*.cs.meta
!**/[Aa]ssets/**/*.unity
!**/[Aa]ssets/**/*.unity.meta
!**/[Pp]ackages/**/*.cs
!**/[Pp]ackages/**/*.cs.meta
!**/[Pp]ackages/**/*.unity
!**/[Pp]ackages/**/*.unity.meta
# Always keep the Unity package manifest
!**/[Pp]ackages/manifest.json
!**/[Pp]ackages/packages-lock.json

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# =============================================================================
# Unity build artifacts
# =============================================================================
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Per-project build output folders that Unity creates on macOS/Android/iOS builds
*_BackUpThisFolder_ButDontShipItWithYourGame/
*_BurstDebugInformation_DoNotShip/
*_ButDontShipItWithYourGame/

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# =============================================================================
# Visual Studio / Rider / VS Code
# =============================================================================
.vs/
.idea/
.vscode/
*.swp

# =============================================================================
# Plastic SCM (Unity's bundled VCS) — don't commit alongside git
# =============================================================================
.plastic/
.utmp/
ignore.conf

# =============================================================================
# OS / misc
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
